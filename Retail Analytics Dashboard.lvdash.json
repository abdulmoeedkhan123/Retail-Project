{
  "datasets": [
    {
      "name": "retail_sales_metrics",
      "displayName": "Retail Sales Metrics",
      "config": {
        "version": "1.1",
        "source": "databricks_simulated_retail_customer_data.v01.sales",
        "dimensions": [
          {
            "name": "order_date",
            "expr": "order_date"
          },
          {
            "name": "product_category",
            "expr": "product_category"
          },
          {
            "name": "customer_id",
            "expr": "customer_id"
          },
          {
            "name": "customer_name",
            "expr": "customer_name"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(total_price)",
            "displayName": "Total Revenue"
          },
          {
            "name": "total_orders",
            "expr": "COUNT(*)",
            "displayName": "Total Orders"
          },
          {
            "name": "unique_customers",
            "expr": "COUNT(DISTINCT customer_id)",
            "displayName": "Unique Customers"
          },
          {
            "name": "avg_order_value",
            "expr": "MEASURE(total_revenue) / MEASURE(total_orders)",
            "displayName": "Average Order Value"
          }
        ]
      }
    },
    {
      "name": "regional_sales",
      "displayName": "Regional Sales",
      "config": {
        "version": "1.1",
        "source": "SELECT \n  s.order_date,\n  s.product_category,\n  s.customer_id,\n  s.customer_name,\n  s.total_price,\n  c.region,\n  c.state,\n  c.city\nFROM databricks_simulated_retail_customer_data.v01.sales s JOIN databricks_simulated_retail_customer_data.v01.customers c \n  ON s.customer_id = c.customer_id\n",
        "dimensions": [
          {
            "name": "order_date",
            "expr": "order_date"
          },
          {
            "name": "region",
            "expr": "region"
          },
          {
            "name": "state",
            "expr": "state"
          },
          {
            "name": "customer_id",
            "expr": "customer_id"
          },
          {
            "name": "customer_name",
            "expr": "customer_name"
          }
        ],
        "measures": [
          {
            "name": "revenue",
            "expr": "SUM(total_price)",
            "displayName": "Revenue"
          },
          {
            "name": "order_count",
            "expr": "COUNT(*)",
            "displayName": "Orders"
          }
        ]
      }
    }
  ],
